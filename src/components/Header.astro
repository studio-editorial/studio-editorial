---
import Container from "./Container.astro";
import { mainNav } from "../data/nav";
import { site } from "../data/site";

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="border-b border-border bg-bg/95 backdrop-blur supports-[backdrop-filter]:bg-bg/80">
  <Container>
    <div class="flex min-h-[72px] items-center justify-between gap-4">
      <a
        href="/"
        class="shrink-0 no-underline"
        aria-label={`${site.name} — accueil`}
      >
        <span class="text-base font-semibold tracking-tight text-fg">
          studio<span class="text-subtle">-editorial.fr</span>
        </span>
      </a>

      <nav
        class="hidden items-center gap-6 md:flex"
        aria-label="Navigation principale"
      >
        {mainNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm no-underline transition-colors",
              isActive(item.href)
                ? "font-medium text-fg"
                : "text-subtle hover:text-fg",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-3 sm:flex">
        <a class="btn-primary" href="/contact">Parler d’un projet</a>
      </div>

      <details class="group ml-auto md:hidden">
        <summary class="inline-flex cursor-pointer list-none items-center justify-center rounded-[var(--radius)] border border-border px-4 py-2 text-sm font-medium text-fg transition-colors hover:bg-surface">
          Menu
        </summary>

        <div class="absolute inset-x-0 top-full z-50 border-b border-border bg-bg/98 backdrop-blur supports-[backdrop-filter]:bg-bg/92">
          <Container>
            <div class="flex flex-col gap-2 py-4">
              {mainNav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "rounded-[var(--radius)] px-3 py-3 text-sm no-underline transition-colors",
                    isActive(item.href)
                      ? "bg-surface font-medium text-fg"
                      : "text-subtle hover:bg-surface hover:text-fg",
                  ]}
                  aria-current={isActive(item.href) ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))}

              <div class="mt-2 pt-2">
                <a class="btn-primary w-full" href="/contact">
                  Parler d’un projet
                </a>
              </div>
            </div>
          </Container>
        </div>
      </details>
    </div>
  </Container>
</header>
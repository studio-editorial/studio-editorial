---
import Container from "./Container.astro";
import { mainNav } from "../data/nav";
import { site } from "../data/site";

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="border-b border-border bg-bg/95 backdrop-blur supports-[backdrop-filter]:bg-bg/80">
  <Container>
    <div class="flex min-h-[72px] items-center justify-between gap-6">
      <a
        href="/"
        class="shrink-0 no-underline"
        aria-label={`${site.name} — accueil`}
      >
        <span class="text-base font-semibold tracking-tight text-fg">
          studio<span class="text-subtle">-editorial.fr</span>
        </span>
      </a>

      <nav
        class="hidden items-center gap-6 md:flex"
        aria-label="Navigation principale"
      >
        {mainNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm no-underline transition-colors",
              isActive(item.href)
                ? "text-fg font-medium"
                : "text-subtle hover:text-fg",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a class="btn-primary hidden sm:inline-flex" href="/contact">
          Parler d’un projet
        </a>
      </div>
    </div>
  </Container>
</header>
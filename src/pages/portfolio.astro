---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import { getCollection } from "astro:content";
import { PORTFOLIO_SECTIONS } from "../data/portfolio";

const getArticleDate = (entry: any) => entry.data.pubDate ?? entry.data.date;

const allProofs = (await getCollection("articles")).filter(
  (entry) => !entry.data.draft && entry.data.portfolio === true
);

const sections = PORTFOLIO_SECTIONS.map((section) => {
  const items = allProofs
    .filter((entry) => entry.data.portfolioSection === section.id)
    .sort((a, b) => {
      const orderDiff =
        (a.data.portfolioOrder ?? 999) - (b.data.portfolioOrder ?? 999);

      if (orderDiff !== 0) return orderDiff;

      return +new Date(getArticleDate(b)) - +new Date(getArticleDate(a));
    });

  return { ...section, items };
}).filter((section) => section.items.length > 0);

const formatDate = (value: Date | string | undefined) => {
  if (!value) return "";
  return new Intl.DateTimeFormat("fr-FR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(new Date(value));
};

const getReadingTime = (entry: any) => {
  if (entry.data.readingTime) return entry.data.readingTime;

  const raw = typeof entry.body === "string" ? entry.body : "";
  const words = raw
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/[#>*_[\]\(\)\-]/g, " ")
    .trim()
    .split(/\s+/)
    .filter(Boolean).length;

  const minutes = Math.max(1, Math.round(words / 220));
  return `${minutes} min`;
};

const formatPortfolioRole = (role: string | undefined) => {
  if (!role) return "";
  return role;
};

const getSectionCta = (sectionId: string) => {
  if (sectionId === "agency-collaboration") {
    return {
      href: "/marque-blanche",
      label: "Voir l’offre adaptée",
    };
  }

  return {
    href: "/services",
    label: "Voir l’intervention adaptée",
  };
};
---

<BaseLayout
  title="Portfolio — Preuves éditoriales pour SaaS, agences et sujets complexes"
  description="Une sélection de pièces organisées par problème : rentabilité SEO, pages SaaS, stratégie éditoriale, sujets techniques et production en marque blanche."
>
  <section class="hero-section page-section">
    <Container>
      <div class="max-w-3xl">
        <p class="kicker">Portfolio</p>
        <h1 class="mt-3 h1 text-balance">
          Des preuves classées selon les problèmes à résoudre, pas selon des formats à exposer.
        </h1>
        <p class="mt-5 lead max-w-2xl">
          Chaque entrée permet de vérifier un point précis : rentabilité du contenu,
          solidité d’une page stratégique, cohérence d’un système éditorial, lisibilité
          d’un sujet technique, ou qualité d’exécution en cadre agence.
        </p>

        <div class="mt-8 grid gap-3 sm:flex sm:flex-wrap">
          <a class="btn-primary" href="/contact">Parler d’un projet</a>
          <a class="btn-secondary" href="/services">Voir les services</a>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-rule bg-surface hero-section page-section">
    <Container>
      <div class="max-w-4xl">
        <p class="kicker">Entrées rapides</p>
        <h2 class="mt-3 h2 text-balance">
          Commencez par le type de preuve dont vous avez besoin.
        </h2>
        <p class="mt-4 body max-w-2xl">
          L’idée n’est pas de tout lire. L’idée est de vérifier rapidement si le studio
          sait traiter le problème qui vous concerne.
        </p>
      </div>

      <div class="mt-10 grid gap-4 lg:grid-cols-2">
        <article class="card bg-bg">
          <h3 class="h3">Relier SEO et rentabilité</h3>
          <p class="mt-3 body">
            Pour vérifier si un contenu est relu au prisme du pipeline, de l’intention
            et de la décision, pas seulement du trafic.
          </p>
        </article>

        <article class="card bg-bg">
          <h3 class="h3">Renforcer une page SaaS à enjeu</h3>
          <p class="mt-3 body">
            Pour vérifier si une page peut devenir un outil de clarification et de décision,
            pas seulement une vitrine mieux formulée.
          </p>
        </article>

        <article class="card bg-bg">
          <h3 class="h3">Structurer un territoire éditorial</h3>
          <p class="mt-3 body">
            Pour vérifier si une logique de contenu dispersée peut être remise en ordre
            sans produire un système artificiel.
          </p>
        </article>

        <article class="card bg-bg">
          <h3 class="h3">Rendre lisible un sujet technique</h3>
          <p class="mt-3 body">
            Pour vérifier si un sujet dense peut être rendu exploitable sans perdre sa tenue.
          </p>
        </article>

        <article class="card bg-bg">
          <h3 class="h3">Diagnostiquer un actif avant reprise</h3>
          <p class="mt-3 body">
            Pour identifier ce qui bloque réellement sur une page, un comparatif ou une landing page
            avant de lancer une reprise trop large, trop vague ou mal ciblée.
          </p>

          <p class="mt-4 body">
            Le point d’entrée le plus concret : une autopsie éditoriale, avec aussi un exemple fictif
            détaillé pour voir comment la lecture s’applique sur un cas SaaS simulé.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a class="btn-secondary" href="/autopsie-editoriale">
              Voir l’offre
            </a>
            <a class="btn-secondary" href="/autopsies">
              Consulter les autopsies
            </a>
          </div>
        </article>

        <article class="card bg-bg">
          <h3 class="h3">Produire proprement dans un cadre agence</h3>
          <p class="mt-3 body">
            Pour vérifier si la collaboration réduit réellement la friction de production,
            au lieu d’ajouter des reprises, des ambiguïtés et de la coordination inutile.
          </p>
        </article>
      </div>
    </Container>
  </section>

  <section class="section-rule hero-section page-section">
    <Container>
      <div class="max-w-4xl">
        <p class="kicker">Pièces</p>
        <h2 class="mt-3 h2 text-balance">
          Chaque section part d’un problème concret, puis montre les preuves utiles.
        </h2>
        <p class="mt-4 body max-w-2xl">
          Inutile de parcourir toute la page. Une ou deux pièces bien choisies
          suffisent généralement à juger le niveau.
        </p>
      </div>

      <div class="mt-12 space-y-16">
        {sections.map((section) => {
          const sectionCta = getSectionCta(section.id);

          return (
            <section class="space-y-6">
              <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
                <div class="max-w-4xl">
                  <p class="kicker">{section.title}</p>
                  <h3 class="mt-3 h3 text-balance max-w-4xl">{section.problem}</h3>
                  <p class="mt-4 body max-w-3xl">{section.promise}</p>
                  <p class="mt-4 body max-w-3xl">
                    <strong>Utile pour :</strong> {section.audience}
                  </p>
                </div>

                <div class="lg:justify-self-start">
                  <a class="btn-secondary" href={sectionCta.href}>
                    {sectionCta.label}
                  </a>
                </div>
              </div>

              <div class="grid gap-4 lg:grid-cols-2">
                {section.items.map((entry) => (
                  <article class="card">
                    <div class="flex flex-wrap gap-3 small">
                      <span>{entry.data.category}</span>
                      <span>·</span>
                      <span>{formatDate(getArticleDate(entry))}</span>
                      <span>·</span>
                      <span>{getReadingTime(entry)}</span>
                    </div>

                    <h4 class="mt-3 h3 text-balance">
                      <a href={`/articles/${entry.id}/`}>{entry.data.title}</a>
                    </h4>

                    {entry.data.portfolioRole && (
                      <p class="mt-3 small">
                        <strong>Rôle :</strong> {formatPortfolioRole(entry.data.portfolioRole)}
                      </p>
                    )}

                    {entry.data.portfolioSummary && (
                      <p class="mt-4 body">{entry.data.portfolioSummary}</p>
                    )}

                    {entry.data.portfolioIntent && (
                      <p class="mt-4 body">
                        <strong>Ce que cela permet de vérifier :</strong>{" "}
                        {entry.data.portfolioIntent}
                      </p>
                    )}

                    {entry.data.portfolioAudience &&
                      entry.data.portfolioAudience.length > 0 && (
                        <p class="mt-4 body">
                          <strong>Lecture utile pour :</strong>{" "}
                          {entry.data.portfolioAudience.join(", ")}
                        </p>
                      )}

                    <div class="mt-6 flex flex-wrap gap-3">
                      <a class="btn-secondary" href={`/articles/${entry.id}/`}>
                        Lire la pièce
                      </a>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    </Container>
  </section>

  <section class="section-rule bg-surface hero-section page-section">
    <Container>
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div class="max-w-2xl">
          <p class="kicker">Suite logique</p>
          <h2 class="mt-3 h2 text-balance">
            Si une de ces pièces recoupe votre problème, le bon réflexe n’est pas de continuer à scroller.
          </h2>
          <p class="mt-4 body">
            Le bon réflexe est de cadrer le besoin : ce qui bloque, ce qu’il faut renforcer,
            et le niveau d’intervention réellement utile.
          </p>
        </div>

        <div class="grid gap-3 sm:flex sm:flex-wrap">
          <a class="btn-primary" href="/contact">Parler d’un projet</a>
          <a class="btn-secondary" href="/autopsies">Consulter les autopsies</a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
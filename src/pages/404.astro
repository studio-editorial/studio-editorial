---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
---

<BaseLayout
  title="404 — Page introuvable"
  description="La page demandée est introuvable. Vous pouvez revenir à l’accueil, consulter les services, le portfolio ou les analyses de Studio Editorial."
  noindex={true}
>
  <section class="py-24 sm:py-28">
    <Container>
      <div class="max-w-4xl">
        <p class="kicker">404</p>
        <h1 class="mt-3 h1 text-balance">
          Cette page n’existe pas, ou n’existe plus.
        </h1>
        <p class="mt-5 lead max-w-3xl">
          Le lien est peut-être obsolète, ou l’URL a changé. Le plus simple est de repartir
          depuis l’une des portes utiles du site.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn-primary" href="/">Revenir à l’accueil</a>
          <a class="btn-secondary" href="/services">Voir les services</a>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-rule bg-surface py-20 sm:py-24">
    <Container>
      <div class="max-w-2xl">
        <p class="kicker">Où aller</p>
        <h2 class="mt-3 h2">Trois points d’entrée utiles</h2>
        <p class="mt-4 body">
          Selon ce que vous cherchiez, voici le chemin le plus direct.
        </p>
      </div>

      <div class="mt-10 grid gap-4 lg:grid-cols-3">
        <a class="card bg-bg hover:no-underline" href="/services">
          <p class="kicker">Offres</p>
          <h3 class="mt-2 h3">Voir les services</h3>
          <p class="mt-3 body">
            Pour identifier le bon type de mission : article d’autorité, page stratégique
            ou renfort éditorial.
          </p>
        </a>

        <a class="card bg-bg hover:no-underline" href="/portfolio">
          <p class="kicker">Preuves</p>
          <h3 class="mt-2 h3">Voir le portfolio</h3>
          <p class="mt-3 body">
            Pour juger le niveau, les angles et les démonstrations éditoriales du studio.
          </p>
        </a>

        <a class="card bg-bg hover:no-underline" href="/articles">
          <p class="kicker">Lecture</p>
          <h3 class="mt-2 h3">Lire les analyses</h3>
          <p class="mt-3 body">
            Pour parcourir la base éditoriale : SEO SaaS, autorité thématique, conversion
            et sujets techniques.
          </p>
        </a>
      </div>
    </Container>
  </section>

  <section class="section-rule py-20 sm:py-24">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="max-w-2xl">
          <h2 class="h2 text-balance">
            Vous cherchiez probablement une page à enjeu.
          </h2>
          <p class="mt-4 body">
            Si le besoin est déjà clair, le plus simple est de repartir des services ou de
            prendre contact directement.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="btn-primary" href="/contact">Parler d’un projet</a>
          <a class="btn-secondary" href="/portfolio">Voir les preuves</a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import { getCollection } from "astro:content";

const getArticleDate = (entry: any) => entry.data.pubDate ?? entry.data.date;

const articles = (await getCollection("articles"))
  .filter((entry) => !entry.data.draft && entry.data.articles !== false)
  .sort((a, b) => +new Date(getArticleDate(b)) - +new Date(getArticleDate(a)));

const featured =
  articles.find((entry) => entry.data.featured) ?? articles[0] ?? null;

const rest = featured
  ? articles.filter((entry) => entry.id !== featured.id)
  : articles;

const formatDate = (value: Date | string | undefined) => {
  if (!value) return "";
  return new Intl.DateTimeFormat("fr-FR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(new Date(value));
};

const getReadingTime = (entry: any) => {
  if (entry.data.readingTime) return entry.data.readingTime;

  const raw = typeof entry.body === "string" ? entry.body : "";
  const words = raw
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/[#>*_[\]\(\)\-]/g, " ")
    .trim()
    .split(/\s+/)
    .filter(Boolean).length;

  const minutes = Math.max(1, Math.round(words / 220));
  return `${minutes} min`;
};
---

<BaseLayout
  title="Articles — SEO SaaS, autorité thématique, conversion et contenu stratégique"
  description="Base éditoriale de Studio Editorial : analyses sur SEO SaaS, autorité thématique, conversion, contenus décisionnels et structuration éditoriale."
>
  <section class="hero-section page-section">
    <Container>
      <div class="max-w-4xl">
        <p class="kicker">Analyses</p>
        <h1 class="mt-3 h1 text-balance">
          Une base éditoriale pour penser acquisition, contenu et conversion autrement.
        </h1>
        <p class="mt-5 lead max-w-3xl">
          Ici, Studio Editorial publie ses analyses : SEO SaaS, intention de recherche,
          autorité thématique, pages à enjeu, logique de portefeuille éditorial.
          Cette page sert à lire. Pas à vendre.
        </p>
      </div>
    </Container>
  </section>

  {featured && (
    <section class="section-rule bg-surface hero-section page-section">
      <Container>
        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <article class="card bg-bg">
            <p class="kicker">Analyse à lire d’abord</p>
            <h2 class="mt-3 h2 text-balance">{featured.data.title}</h2>

            <div class="mt-4 flex flex-wrap gap-3 small">
              <span>{featured.data.category}</span>
              <span>·</span>
              <span>{formatDate(getArticleDate(featured))}</span>
              <span>·</span>
              <span>{getReadingTime(featured)}</span>
            </div>

            <p class="mt-5 body">{featured.data.description}</p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a class="btn-primary" href={`/articles/${featured.id}/`}>
                Lire l’analyse
              </a>
              <a class="btn-secondary" href="/portfolio">
                Voir les preuves
              </a>
            </div>
          </article>

          <div class="card">
            <p class="kicker">Rôle de cette page</p>
            <p class="mt-3 body">
              L’archive rassemble la ligne éditoriale du studio. Le portfolio, lui,
              sélectionne certaines pièces pour répondre à des objections commerciales
              précises. Les deux pages ne servent pas le même usage.
            </p>

            <ul class="mt-5 list-disc space-y-2 pl-5 body">
              <li>Ici : lecture chronologique et base de pensée</li>
              <li>Portfolio : preuves triées par angle commercial</li>
              <li>Services : ce qu’un client peut réellement acheter</li>
            </ul>
          </div>
        </div>
      </Container>
    </section>
  )}

  <section class="section-rule hero-section page-section">
    <Container>
      <div class="max-w-2xl">
        <p class="kicker">Archive</p>
        <h2 class="mt-3 h2">Toutes les analyses publiées</h2>
        <p class="mt-4 body">
          Triées par date de publication, sans couche marketing inutile.
        </p>
      </div>

      {rest.length > 0 ? (
        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          {rest.map((entry) => (
            <article class="card">
              <div class="flex flex-wrap gap-3 small">
                <span>{entry.data.category}</span>
                <span>·</span>
                <span>{formatDate(getArticleDate(entry))}</span>
                <span>·</span>
                <span>{getReadingTime(entry)}</span>
              </div>

              <h3 class="mt-3 h3 text-balance">
                <a href={`/articles/${entry.id}/`}>{entry.data.title}</a>
              </h3>

              <p class="mt-3 body">{entry.data.description}</p>

              {entry.data.tags && entry.data.tags.length > 0 && (
                <ul class="mt-5 flex flex-wrap gap-2">
                  {entry.data.tags.slice(0, 4).map((tag: string) => (
                    <li class="rounded-full border border-border px-3 py-1 small">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}

              <div class="mt-6">
                <a class="btn-secondary" href={`/articles/${entry.id}/`}>
                  Lire
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="mt-10 card">
          <p class="h3">Aucune analyse publiée pour l’instant.</p>
        </div>
      )}
    </Container>
  </section>

  <section class="section-rule bg-surface hero-section page-section">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="max-w-2xl">
          <h2 class="h2 text-balance">
            Vous ne cherchez pas seulement à lire ?
          </h2>
          <p class="mt-4 body">
            Le portfolio montre quelles pièces répondent à quelles objections commerciales.
            La page services montre ce qu’il est possible de commander.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
            <a class="btn-primary" href="/portfolio">Voir le portfolio</a>
            <a class="btn-secondary" href="/services">Voir les services</a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import { getCollection, render } from "astro:content";

const getArticleDate = (article: any) => article.data.pubDate ?? article.data.date;

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const title = article.data.seoTitle ?? article.data.title;
const description = article.data.seoDescription ?? article.data.description;

const formatDate = (date: Date | string) =>
  new Intl.DateTimeFormat("fr-FR", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(new Date(date));
---

<BaseLayout title={title} description={description}>
  <main class="bg-bg text-fg">
    <article class="py-20 sm:py-24">
      <Container>
        <header class="mx-auto max-w-3xl">
          <p class="kicker">{article.data.category}</p>
          <h1 class="mt-3 h1">{article.data.title}</h1>
          <p class="mt-5 lead">{article.data.description}</p>

          <div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 small border-t border-border pt-6">
            <span>{formatDate(getArticleDate(article))}</span>
            {article.data.updatedAt && (
              <span>Mise à jour : {formatDate(article.data.updatedAt)}</span>
            )}
            {article.data.readingTime && <span>{article.data.readingTime}</span>}
          </div>
        </header>

        <div class="mx-auto mt-14 max-w-3xl article-content">
          <Content />
        </div>

        <footer class="mx-auto mt-16 max-w-3xl border-t border-border pt-8">
          <p class="body">
            Studio Editorial conçoit des contenus stratégiques pour SaaS et entreprises
            tech : articles d’autorité, pages stratégiques et renfort éditorial en
            marque blanche.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a class="btn-primary" href="/services">Voir les services</a>
            <a class="btn-secondary" href="/contact">Parler d’un projet</a>
          </div>
        </footer>
      </Container>
    </article>
  </main>
</BaseLayout>
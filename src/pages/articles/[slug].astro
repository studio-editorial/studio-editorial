---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import { getCollection, render } from "astro:content";

const getArticleDate = (article: any) => article.data.pubDate ?? article.data.date;

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const title = article.data.seoTitle ?? article.data.title;
const description = article.data.seoDescription ?? article.data.description;

const formatDate = (date: Date | string) =>
  new Intl.DateTimeFormat("fr-FR", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(new Date(date));
---

<BaseLayout title={title} description={description} type="article">
  <main class="bg-bg text-fg">
    <article class="article-shell">
      <Container>
        <div class="article-wrap">
          <header class="article-header">
            {article.data.category && (
              <p class="article-kicker">{article.data.category}</p>
            )}

            <h1 class="article-title">{article.data.title}</h1>

            {article.data.description && (
              <p class="article-standfirst">{article.data.description}</p>
            )}

            <div class="article-meta">
              <span>{formatDate(getArticleDate(article))}</span>
              {article.data.updatedAt && (
                <span> · Mise à jour : {formatDate(article.data.updatedAt)}</span>
              )}
              {article.data.readingTime && <span> · {article.data.readingTime}</span>}
            </div>
          </header>

          <div class="article-content">
            <Content />
          </div>

          <footer class="article-footer">
            <p class="article-footer-text">
              Studio Editorial conçoit des contenus stratégiques pour SaaS et entreprises
              tech : articles d’autorité, pages stratégiques et renfort éditorial en
              marque blanche.
            </p>

            <div class="article-footer-actions">
              <a class="btn-primary" href="/services">Voir les services</a>
              <a class="btn-secondary" href="/contact">Parler d’un projet</a>
            </div>
          </footer>
        </div>
      </Container>
    </article>
  </main>
</BaseLayout>